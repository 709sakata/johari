{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "The display name of the user." },
        "photoURL": { "type": "string", "description": "The photo URL of the user." },
        "bio": { "type": "string", "description": "A short self-introduction of the user." },
        "links": {
          "type": "array",
          "items": { "type": "string" },
          "description": "A list of URLs related to the user (supports 100+ links)."
        },
        "updatedAt": { "type": "string", "format": "date-time", "description": "The last update timestamp." }
      },
      "required": ["displayName", "updatedAt"]
    },
    "scrap": {
      "title": "Scrap",
      "description": "A scrap thread containing technical notes.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the scrap." },
        "status": { "type": "string", "enum": ["open", "closed"], "description": "The status of the scrap." },
        "authorId": { "type": "string", "description": "The UID of the author." },
        "authorName": { "type": "string", "description": "The display name of the author." },
        "authorPhoto": { "type": "string", "description": "The photo URL of the author." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation timestamp." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "The last update timestamp." },
        "icon_emoji": { "type": "string", "description": "Emoji icon for the scrap" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "User-defined tags for the scrap"
        }
      },
      "required": ["title", "status", "authorId", "authorName", "createdAt", "updatedAt"]
    },
    "comment": {
      "title": "Comment",
      "description": "A comment within a scrap thread.",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "The markdown content of the comment." },
        "authorId": { "type": "string", "description": "The UID of the author." },
        "authorName": { "type": "string", "description": "The display name of the author." },
        "authorPhoto": { "type": "string", "description": "The photo URL of the author." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation timestamp." },
        "parentId": { "type": "string", "description": "The ID of the parent comment, if this is a reply." },
        "images": { 
          "type": "object", 
          "description": "A map of image IDs to base64 encoded data."
        }
      },
      "required": ["content", "authorId", "authorName", "createdAt"]
    },
    "feed": {
      "title": "Feed",
      "description": "An RSS feed subscription.",
      "type": "object",
      "properties": {
        "url": { "type": "string", "description": "The URL of the RSS feed." },
        "title": { "type": "string", "description": "The title of the feed." },
        "authorId": { "type": "string", "description": "The UID of the subscriber." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation timestamp." }
      },
      "required": ["url", "title", "authorId", "createdAt"]
    },
    "identity_task": {
      "title": "QATask",
      "description": "A question generated by the Q&A Audit Agent.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user." },
        "type": { "type": "string", "enum": ["fact-check", "meta-cognition"], "description": "The type of task." },
        "question": { "type": "string", "description": "The question posed by the agent." },
        "status": { "type": "string", "enum": ["pending", "completed"], "description": "The status of the task." },
        "answer": { "type": "string", "description": "The user's answer to the task." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation timestamp." }
      },
      "required": ["userId", "type", "question", "status", "createdAt"]
    },
    "qa_comment": {
      "title": "QAComment",
      "description": "A follow-up comment or reflection on a Q&A task.",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "The markdown content of the comment." },
        "authorId": { "type": "string", "description": "The UID of the author." },
        "authorName": { "type": "string", "description": "The display name of the author." },
        "authorPhoto": { "type": "string", "description": "The photo URL of the author." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation timestamp." }
      },
      "required": ["content", "authorId", "authorName", "createdAt"]
    },
    "identity_state": {
      "title": "IdentityState",
      "description": "The synthesized state of a user's identity (Digital Twin).",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user." },
        "coreLogic": { "type": "string", "description": "The core behavioral principles of the user." },
        "publicNarrative": { "type": "string", "description": "The external narrative/persona." },
        "shadowNarrative": { "type": "string", "description": "The internal/hidden truth (shadow)." },
        "unresolvedConflict": { "type": "string", "description": "Identified contradictions or unresolved points." },
        "evolutionLog": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "string", "format": "date-time" },
              "scrapId": { "type": "string" },
              "changeDescription": { "type": "string" }
            }
          }
        },
        "lastScrapId": { "type": "string", "description": "The ID of the last scrap processed in the incremental loop." },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "coreLogic", "publicNarrative", "shadowNarrative", "unresolvedConflict", "updatedAt"]
    },
    "activity_log": {
      "title": "ActivityLog",
      "description": "A log of user activity for analytics.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user (optional for anonymous)." },
        "type": { "type": "string", "enum": ["page_view", "action"], "description": "The type of activity." },
        "path": { "type": "string", "description": "The page path." },
        "action": { "type": "string", "description": "The specific action performed." },
        "metadata": { "type": "object", "description": "Additional context for the activity." },
        "userAgent": { "type": "string", "description": "The user agent string." },
        "timestamp": { "type": "string", "format": "date-time", "description": "The timestamp of the activity." }
      },
      "required": ["type", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "Collection of user profile information."
    },
    "/scraps/{scrapId}": {
      "schema": "scrap",
      "description": "Collection of scrap threads."
    },
    "/scraps/{scrapId}/comments/{commentId}": {
      "schema": "comment",
      "description": "Subcollection of comments for a specific scrap."
    },
    "/feeds/{feedId}": {
      "schema": "feed",
      "description": "Collection of RSS feed subscriptions."
    },
    "/identity_tasks/{taskId}": {
      "schema": "identity_task",
      "description": "Collection of Q&A tasks."
    },
    "/identity_tasks/{taskId}/qa_comments/{commentId}": {
      "schema": "qa_comment",
      "description": "Subcollection of follow-up comments for a Q&A task."
    },
    "/identity_states/{stateId}": {
      "schema": "identity_state",
      "description": "Collection of user identity states (Digital Twin)."
    },
    "/activity_logs/{logId}": {
      "schema": "activity_log",
      "description": "Collection of user activity logs for analytics."
    }
  }
}
